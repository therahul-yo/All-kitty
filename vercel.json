{
  "version": 2,
  "name": "allkitty",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/downloads/(.*)",
      "dest": "public/downloads/$1"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}
